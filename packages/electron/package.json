{
  "name": "@webpilot/onboarding",
  "version": "2.0.2",
  "private": true,
  "author": "WebPilot",
  "description": "WebPilot onboarding UI",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --publish never",
