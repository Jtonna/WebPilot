{
  "version": "2",
  "platforms": {
    "discord": {
      "match": "discord.com",
      "entry": "discord/discord.js"
    },
    "threads": {
      "match": "threads.com",
      "entry": "threads/router.js"
    },
    "zillow": {
      "match": "zillow.com",
      "entry": "zillow/router.js"
    }
  },
  "default": "default.js",
  "files": [
    "default.js",
    "discord/manifest.json",
    "discord/discord.js",
    "discord/workflows.js",
    "threads/manifest.json",
    "threads/router.js",
    "threads/home.js",
    "threads/search.js",
    "threads/activity.js",
    "zillow/manifest.json",
    "zillow/router.js",
    "zillow/home.js",
    "zillow/search.js",
    "zillow/detail.js",
    "zillow/detail_page.js"
  ]
}
