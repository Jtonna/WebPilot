# Dependencies
node_modules/

# Build output
dist/
build/
# electron-builder's NSIS installer hook lives here and must be tracked.
!packages/electron/build/
!packages/electron/build/**
*.crx
*.pem
*.zip

# Environment and secrets
.env
.env.*

# OS files
Thumbs.db
Desktop.ini
.DS_Store
._*

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
# Web-UI route directory accidentally caught by `logs/` above — un-ignore.
!packages/server-web-ui/app/formatters/logs/
!packages/server-web-ui/app/formatters/logs/**

# Coverage and testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/

# Build output - pkg compiled binaries
*.exe
!packages/chrome-extension-unpacked/icons/*

# pkg build cache
.pkg-cache/
pkg-cache/

# Additional environment and secrets
config.local.json

# Storybook (dev-only — never shipped in the daemon's bundled UI)
packages/server-web-ui/storybook-static/
packages/server-web-ui/debug-storybook.log

# Additional editor files
*.code-workspace
/packages/electron/.next
/packages/electron/out
.claude/settings.local.json

# starterpack — these paths must be tracked by git
!.starterpack/
!.starterpack/**
!.claude/
!.claude/**
!.github/
!.github/**
!CLAUDE.md
!.gitattributes
.mcp.json
